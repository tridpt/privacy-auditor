{
  "manifest_version": 3,
  "name": "Privacy Auditor",
  "version": "1.0.0",
  "description": "Real-time privacy analysis — detect trackers, fingerprinting & data collection on any website",
  "permissions": [
    "webRequest",
    "storage",
    "cookies",
    "tabs",
    "activeTab",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Privacy Auditor"
  }
}
